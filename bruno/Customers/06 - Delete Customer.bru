meta {
  name: 06 - Delete Customer
  type: http
  seq: 6
}

delete {
  url: {{baseUrl}}/api/v1/customers/{{customerId}}
  body: none
  auth: none
}

tests {
  const status = typeof res.getStatus === 'function' ? res.getStatus() : res.status;

  test("status is 204", function () {
    expect(status).to.equal(204);
  });
}
